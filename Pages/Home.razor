@page "/"
@inject NavigationManager Nav

<div class="bg-overlay"></div>

<div class="container">
    <header class="profile-wrap">
        <div class="scanner-box">
            <img src="images/profile.jpg" class="profile-img" alt="SHADY" />
            <div class="scan-line"></div>
        </div>
        <h1 class="glitch-text">Benjamin Joshua Tecson</h1>
        <div class="status-chip">SYSTEM_STATUS: ACTIVE</div>
        <p class="sub-header">BSIT</p>
    </header>

    <div class="grid-layout">
        <div class="grid-cell" style="grid-column: span 2;">
            <span class="line-number">001</span>
            <h2>Log.01: About</h2>
            <p>Full-stack developer focused on the intersection of PHP/Blazor logic and arcane visual aesthetics. Currently engineering high-performance web applications under a dark-mode philosophy.</p>
        </div>

        <div class="grid-cell">
            <span class="line-number">002</span>
            <h3>THRIFTUAL</h3>
            <p>Gothic Underground Marketplace. Full-stack PHP/SQL integration.</p>
            <button class="btn-void" @onclick='() => Nav.NavigateTo("thriftual")'>Initialize_Stream</button>
        </div>

        <div class="grid-cell">
            <span class="line-number">003</span>
            <h3>CALCULATOR</h3>
            <p>Functional XML-based history tracking. Clean UI architecture.</p>
            <button class="btn-void" @onclick='() => Nav.NavigateTo("calculator")'>Initialize_Stream</button>
        </div>
        
        <div class="grid-cell">
            <span class="line-number">004</span>
            <h3>TECSON FORUMS</h3>
            <p>Modern forum application using JSON data storage and real-time JS updates.</p>
            <button class="btn-void" @onclick='() => Nav.NavigateTo("forum")'>Initialize_Stream</button>
        </div>

        <div class="grid-cell">
            <span class="line-number">005</span>
            <h3>CONTACT</h3>
            <p>Inquiries: benjaminjoshuatecson@gmail.com</p>
            <div style="display: flex; gap: 20px; margin-top: 15px;">
                <a href="https://github.com" class="btn-void">Github</a>
                <a href="https://discord.com" class="btn-void">Discord</a>
            </div>
        </div>
    </div>

    <footer class="system-signature">
        <div class="vertical-connector"></div>
        
        <div class="alias-container">
            <span class="prefix">DESIGNED_BY</span>
            <h2 class="alias-text">SHADY_FROM_FET</h2>
        </div>

        <div class="social-grid">
            <a href="https://facebook.com/yourprofile" target="_blank" class="social-hex" aria-label="Facebook">
                <i class="fab fa-facebook-f"></i>
            </a>
            <a href="https://instagram.com/yourprofile" target="_blank" class="social-hex" aria-label="Instagram">
                <i class="fab fa-instagram"></i>
            </a>
        </div>

        <div class="status-bar">
            <span>CORE_V1.0</span>
            <span class="blink">●</span>
            <span>ENCRYPTED_CONNECTION</span>
        </div>
    </footer>
</div>

<style>
    /* Scoped styles to keep the Home page looking sharp */
    .sub-header {
        letter-spacing: 5px; 
        font-size: 12px;
        color: #444;
        margin-top: 10px;
    }

    .scanner-box {
        position: relative;
        display: inline-block;
        margin-bottom: 20px;
        border: 1px solid #1a1a1a;
        line-height: 0;
    }

    .scan-line {
        position: absolute;
        top: 0; left: 0;
        width: 100%; height: 2px;
        background: #fff;
        box-shadow: 0 0 15px #fff;
        animation: scan 4s infinite ease-in-out;
        opacity: 0.6;
        z-index: 2;
    }

    @@keyframes scan {
        0%, 100% { top: 0%; }
        50% { top: 100%; }
    }

    .status-chip {
        display: inline-block;
        padding: 2px 10px;
        border: 1px solid #333;
        font-size: 9px;
        color: #0f0; 
        text-transform: uppercase;
        margin-top: 10px;
    }

    .line-number {
        font-size: 10px;
        color: #222;
        display: block;
        margin-bottom: 10px;
        font-family: 'JetBrains Mono', monospace;
    }

    /* Footer Centering & Sigil Logic */
    .system-signature {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 100px 0 40px 0;
    }

    .vertical-connector {
        width: 1px;
        height: 80px;
        background: linear-gradient(to bottom, transparent, #222, #fff);
        margin-bottom: 30px;
    }

    .social-grid {
        display: flex;
        gap: 25px;
        margin-bottom: 30px;
    }

    .social-hex {
        color: #a0a0a0;
        font-size: 18px;
        width: 45px;
        height: 45px;
        border: 1px solid #222;
        display: flex;
        align-items: center;
        justify-content: center;
        text-decoration: none;
        transform: rotate(45deg);
        transition: 0.3s;
    }

    .social-hex i { transform: rotate(-45deg); }

    .social-hex:hover {
        border-color: #fff;
        color: #fff;
        background: rgba(255,255,255,0.05);
    }

    .blink { animation: blinker 2s linear infinite; }
    @@keyframes blinker { 50% { opacity: 0; } }
</style>